{
    "xlview": {
        "prefix": "xlview",
        "body": [
            "import xlwings as xw",
            "xw.view($1)",
        ],
    },
    "xlws": {
        "prefix": "xlws",
        "body": [
            "ws = xw.books.active.sheets['Sheet1']",
            "# ws = xw.Book().sheets['Sheet1']",
            "# ws = xw.sheets.active",
        ],
    },
    "xlread": {
        "prefix": "xlread",
        "body": [
            "df2 = xw.sheets.active['$2'].expand().options(pd.DataFrame).value",
            "df2",
        ],
    },
    "xlwritenewsht": {
        "prefix": "xlwritenewsht",
        "body": [
            "ws = xw.books.active.sheets.add('$1')",
            "ws[\"A1\"].value = $1",
            "ws.tables.add(source=ws[\"A1\"].expand())",
        ],
    },
    "xlwrite": {
        "prefix": "xlwrite",
        "body": [
            "ws = xw.sheets.active",
            "ws[\"$2\"].value = $1",
            "ws.tables.add(source=ws[\"$2\"].expand())",
        ],
    },
    "xlpivot": {
        "prefix": "xlpivot",
        "body": [
            "pivot_cache = ws.book.api.PivotCaches().Create(",
            "    SourceType=1,  # xlDatabase",
            "    SourceData=\"$1\",",
            ")",
            "pt = pivot_cache.CreatePivotTable(",
            "    TableDestination=ws[\"$2\"].api,",
            "    TableName=\"Pivot$3\",",
            ")",
            "",
            "pt.PivotFields(\"$4\").Orientation = 1  # xlRowField",
            "pt.AddDataField(pt.PivotFields(\"$5\"), \"Avg of $5\", xw.constants.ConsolidationFunction.xlAverage)",
        ],
    },
    "xlchart": {
        "prefix": "xlchart",
        "body": [
            "chart = ws.charts.add(",
            "    top=ws['$1'].top, left=ws['$1'].left",
            ")",
            "chart.chart_type = 'line'",
            "chart.set_source_data(ws['$2'].expand())",
        ],
    },
    "xlslicer": {
        "prefix": "xlslicer",
        "body": [
            "sc = ws.book.api.SlicerCaches.Add2(",
            "    Source=pt,",
            "    SourceField=\"$1\",",
            ")",
            "",
            "slicer = sc.Slicers.Add(",
            "    SlicerDestination=ws.api,",
            "    Width=100,",
            "    Height=200,",
            ")",
            "slicer.Top = 200",
            "slicer.Left = 900",
        ],
    },
    "xlpivdash": {
        "prefix": "xlpivdash",
        "body": [
            "import xlwings as xw",
            "wb = xw.Book()",
            "dashboard = PivotDashboard(wb)",
            "dashboard.write_table(df, code=$1)",
            "",
            "pivot_configs = [",
            "    # fmt: off",
            "    dict(data_field=\"n\",row_field=$2,col_field=$3,chart_type=\"area_stacked\",),",
            "    # fmt: on",
            "]",
            "dashboard.add_pivots(pivot_configs)",
            "",
            "dashboard.add_slicers(",
            "    fields=[",
            "        $2,",
            "        $3,",
            "    ],",
            ")",
        ],
    }
}