{
    "xlview": {
        "prefix": "xlview",
        "body": [
            "import xlwings as xw",
            "xw.view($1)",
        ],
    },
    "xlread": {
        "prefix": "xlread",
        "body": [
            "import xlwings as xw",
            "import pandas as pd",
            "ws2 = xw.books.active.sheets['$1']",
            "df2 = ws2['A1'].expand().options(pd.DataFrame).value",
            "df2",
        ],
    },
    "xlwrite": {
        "prefix": "xlwrite",
        "body": [
            "import xlwings as xw",
            "ws = xw.books.active.sheets.add('$1')",
            "ws[\"A1\"].value = $1",
            "ws.tables.add(source=ws[\"A1\"].expand())",
        ],
    },
    "xlpivdash": {
        "prefix": "xlpivdash",
        "body": [
            "import xlwings as xw",
            "wb = xw.Book()",
            "dashboard = PivotDashboard(wb)",
            "dashboard.write_table(df, code=$1)",
            "",
            "pivot_configs = [",
            "    # fmt: off",
            "    dict(data_field=\"n\",row_field=$2,col_field=$3,chart_type=\"area_stacked\",),",
            "    # fmt: on",
            "]",
            "dashboard.add_pivots(pivot_configs)",
            "",
            "dashboard.add_slicers(",
            "    fields=[",
            "        $2,",
            "        $3,",
            "    ],",
            ")",
        ],
    }
}