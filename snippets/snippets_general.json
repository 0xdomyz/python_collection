{
    "peq": {
        "prefix": "peq",
        "body": [
            "print(f\"{$0 = }\")",
        ],
    },
    "forp": {
        "prefix": "forp",
        "body": [
            "for i in $0:",
            "    print(i)",
        ],
    },
    "lcomp": {
        "prefix": "lcomp",
        "body": [
            "[i$1 for i in $2]",
        ],
    },
    "withopen": {
        "prefix": "withopen",
        "body": [
            "with open(\"$1\", 'r') as f:",
            "    $2 = f.read()",
        ],
    },
    "iterdir": {
        "prefix": "iterdir",
        "body": [
            "for i in ($1).iterdir():",
            "    print(i.name)",
        ],
    },
    "today": {
        "prefix": "today",
        "body": [
            "import datetime",
            "",
            "today_dt = datetime.datetime.now().strftime('%Y%m%d')",
            "today_dt",
        ],
    },
    "pdb": {
        "prefix": "pdb",
        "body": [
            "import pdb; pdb.set_trace()",
        ],
    },
    "writeqry": {
        "prefix": "writeqry",
        "body": [
            "with open(Path('sql') / \"$1.sql\"), \"w\") as f:",
            "    f.write(qry)",
        ],
    },
    "logurudebug": {
        "prefix": "logurudebug",
        "body": [
            "import sys",
            "from loguru import logger",
            "logger.add(sys.stdout, level=\"DEBUG\")",
        ],
    },
    "xwview": {
        "prefix": "xwview",
        "body": [
            "import xlwings as xw",
            "xw.view($1)",
        ],
    },
    "xwdata": {
        "prefix": "xwdata",
        "body": [
            "import xlwings as xw",
            "wb = xw.Book()",
            "ws = wb.sheets[0]",
            "ws.name = \"Data\"",
            "",
            "ws.clear()",
            "ws[\"A1\"].value = df$1",
            "ws.tables.add(source=ws[\"A1\"].expand(), name=\"Data1\")",
        ],
    },
    "xwdatas": {
        "prefix": "xwdatas",
        "body": [
            "import xlwings as xw",
            "",
            "wb = xw.Book()",
            "ws1 = wb.sheets[0]",
            "ws1[\"A1\"].value = $1",
            "ws1.tables.add(source=ws1[\"A1\"].expand(), name=\"Data1\")",
            "",
            "ws2 = wb.sheets.add(\"Sheet2\", after=ws1)",
            "ws2[\"A1\"].value = $2",
            "ws2.tables.add(source=ws2[\"A1\"].expand(), name=\"Data2\")",
            "",
            "ws2[\"$3\"].value = $4",
            "ws2.tables.add(source=ws2[\"$3\"].expand(), name=\"Data3\")"
        ]
    },
    "xwpivdash": {
        "prefix": "xwpivdash",
        "body": [
            "import xlwings as xw",
            "wb = xw.Book()",
            "dashboard = PivotDashboard(wb)",
            "dashboard.write_table(df, code=$1)",
            "",
            "pivot_configs = [",
            "    # fmt: off",
            "    dict(data_field=\"n\",row_field=$2,col_field=$3,chart_type=\"area_stacked\",),",
            "    # fmt: on",
            "]",
            "dashboard.add_pivots(pivot_configs)",
            "",
            "dashboard.add_slicers(",
            "    fields=[",
            "        $2,",
            "        $3,",
            "    ],",
            ")",
        ],
    }
}