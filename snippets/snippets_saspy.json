{
    // saspy related
    "sassetup": {
        "prefix": "sassetup",
        "body": [
            "import saspy",
            "",
            "sas = saspy.SASsession()",
            "sas",
        ],
    },
    "sassetupcfg": {
        "prefix": "sassetupcfg",
        "body": [
            "import saspy  # isort: skip",
            "from pathlib import Path  # isort: skip",
            "",
            "print(Path(saspy.SAScfg).as_posix())",
        ],
    },
    "sassetuplib": {
        "prefix": "sassetuplib",
        "body": [
            "sas.submitLST(",
            "    rf\"\"\"",
            "%let myvar=myvalue;",
            "libname mylib 'C:\\temp';",
            "\"\"\",",
            "    method=\"listonly\",",
            ")",
        ],
    },
    "sashead": {
        "prefix": "sashead",
        "body": [
            "df_h = sas.sasdata($2, $1).head()",
            "df_h",
        ],
    },
    "sascount": {
        "prefix": "sascount",
        "body": [
            "n_obs = sas.sasdata($2, $1).obs()",
            "n_obs",
        ],
    },
    "sasshape": {
        "prefix": "sasshape",
        "body": [
            "sd = sas.sasdata($2, $1)",
            "_shape = (sd.obs(), len(sd.columnInfo()))",
            "print(_shape)",
        ],
    },
    "sastop": {
        "prefix": "sastop",
        "body": [
            "df_h1 = sas.sasdata($2, $1).head(1)",
            "print(df_h1.T.to_string())",
        ],
    },
    "sasshapehead": {
        "prefix": "sasshapehead",
        "body": [
            "sd = sas.sasdata($2, $1)",
            "_shape, df_h = (sd.obs(), len(sd.columnInfo())), sd.head()",
            "print(_shape)",
            "df_h",
        ],
    },
    "sasinfo": {
        "prefix": "sasinfo",
        "body": [
            "df_info = sas.sasdata($2, $1).columnInfo()",
            "df_info",
        ],
    },
    "sascol": {
        "prefix": "sascol",
        "body": [
            "df_info = sas.sasdata($2, $1).columnInfo()",
            "cols = df_info[\"Variable\"].tolist()",
            "[c for c in cols if $3 in c.lower()]",
        ],
    },
    "sasvalc": {
        "prefix": "sasvalc",
        "body": [
            "sas.submitLST(",
            "    f\"\"\"",
            "proc sql;",
            "create table _tmp as",
            "    select",
            "        $3,",
            "        count(1) as n",
            "    from $1",
            "    where $2",
            "    group by 1",
            "    order by 1;",
            "quit;",
            "\"\"\",",
            "    method=\"listonly\",",
            ")",
            "df = sas.sasdata(\"_tmp\", \"work\").to_df()",
            "df",
        ],
    },
    "sasrun": {
        "prefix": "sasrun",
        "body": [
            "sas.submitLST(",
            "    f\"\"\"",
            "proc print data=$1 (obs=5);",
            "run;",
            "\"\"\",",
            "    method=\"listonly\",",
            ")",
        ],
    },
    "sasrunlog": {
        "prefix": "sasrunlog",
        "body": [
            "sas.submitLST(",
            "    f\"\"\"",
            "proc print data=$1 (obs=5);",
            "run;",
            "\"\"\",",
            "    method=\"listandlog\",",
            ")",
        ],
    },
    "sasgrp": {
        "prefix": "sasgrp",
        "body": [
            "sas.submitLST(",
            "    f\"\"\"",
            "proc sql;",
            "create table _tmp as",
            "    select",
            "        $3,",
            "        $4,",
            "        count(1) as n",
            "    from $1",
            "    where $2",
            "    group by 1,2",
            "    order by 1,2;",
            "quit;",
            "\"\"\",",
            "    method=\"listonly\",",
            ")",
            "df = sas.sasdata(\"_tmp\", \"work\").to_df()",
            "df",
        ],
    },
    "sasuni": {
        "prefix": "sasuni",
        "body": [
            "sas.submitLST(",
            "    f\"\"\"",
            "title;",
            "proc univariate data=$1;",
            "    var $2;",
            "    histogram $2 / lognormal;",
            "run;",
            "\"\"\",",
            "    method=\"listonly\",",
            ")",
        ],
    },
    "sasfreq": {
        "prefix": "sasfreq",
        "body": [
            "sas.submitLST(",
            "    f\"\"\"",
            "title;",
            "proc freq data=$1;",
            "    tables $2 / chisq;",
            "run;",
            "\"\"\",",
            "    method=\"listonly\",",
            ")",
        ],
    },
    "saslogi": {
        "prefix": "saslogi",
        "body": [
            "sas.submitLST(",
            "    f\"\"\"",
            "proc logistic data=$1 plots(only)=roc;",
            "    where $2 in (0,1);",
            "    model $2(event=1) = $3;",
            "    output out=work._pred p=phat;",
            "run;",
            "\"\"\",",
            "    method=\"listonly\",",
            ")",
        ],
    },
    "sassfa": {
        "prefix": "sassfa",
        "body": [
            "sas.submitLST(",
            "    f\"\"\"",
            "proc rank",
            "    data=$1(where=($2 in (0,1)))",
            "    out=_tmp_h_dec",
            "    groups=10;",
            "    var $3;",
            "    ranks decile0;",
            "run;",
            "",
            "proc sql;",
            "create table _tmp_rates as",
            "select",
            "    case",
            "        when missing(decile0) then 'NA'",
            "        else strip(put(decile0, 2.))",
            "    end as decile,",
            "    count(*) as n,",
            "    mean($2=1) as rate",
            "from _tmp_h_dec",
            "group by decile0",
            "order by decile;",
            "quit;",
            "",
            "proc sgplot data=_tmp_rates;",
            "    vbarparm category=decile response=n / datalabel transparency=0.15;",
            "    series x=decile y=rate / y2axis markers lineattrs=(thickness=2);",
            "    yaxis  label='Volume';",
            "    y2axis label='Rate' values=(0 to 1 by 0.1);",
            "    xaxis  label='Decile' integer;",
            "run;",
            "    \"\"\",",
            "    method=\"listonly\",",
            ")",
        ],
    },
    "sasqry": {
        "prefix": "sasqry",
        "body": [
            "sas.submitLST(",
            "    f\"\"\"",
            "proc sql;",
            "create table _tmp as",
            "    select",
            "        a.$3,",
            "        b.$4,",
            "        count(1) as n",
            "    from $1 a",
            "    left join $2 b",
            "    on",
            "        a.$3 = b.$3 and",
            "        a.$4 = b.$4",
            "    where",
            "        $5",
            "    group by 1,2",
            "    order by 1,2",
            "    ;",
            "quit;",
            "\"\"\",",
            "    method=\"listonly\",",
            ")",
            "",
            "df = sas.sasdata(\"_tmp\", \"work\").to_df()",
            "df",
        ],
    },
    "sasdrop": {
        "prefix": "sasdrop",
        "body": [
            "sas.submitLST(f\"proc sql;drop table $1;quit;\", method=\"listonly\")",
        ],
    },
    "saswrite": {
        "prefix": "saswrite",
        "body": [
            "sas.df2sd(df, $1, $2)",
        ],
    },
    "sasctbl": {
        "prefix": "sasctbl",
        "body": [
            "sas.submitLST(f\"proc sql;drop table $1;quit;\", method=\"listonly\")",
            "",
            "sas.submitLST(",
            "    f\"\"\"",
            "proc sql;",
            "create table $1 as",
            "    select",
            "        a.$4,",
            "        b.$5,",
            "        count(1) as n",
            "    from $2 a",
            "    left join $3 b",
            "    on",
            "        a.$4 = b.$4 and",
            "        a.$5 = b.$5",
            "    where",
            "        $6",
            "    group by 1,2",
            "    order by 1,2",
            "    ;",
            "quit;",
            "\"\"\",",
            "    method=\"listonly\",",
            ")",
            "",
            "sas.sasdata(f\"$1\".split('.')[1], f\"$1\".split('.')[0]).obs()",
        ],
    },
    "saserrors": {
        "prefix": "saserrors",
        "body": [
            "print(f\"{sas.saslog().count('ERROR') = }\")",
        ],
    },
    "saslog": {
        "prefix": "saslog",
        "body": [
            "print(sas.lastlog())",
        ],
    }
}