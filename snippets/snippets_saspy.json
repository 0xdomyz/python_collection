{
    // saspy related
    "sassetup": {
        "prefix": "sassetup",
        "body": [
            "import saspy",
            "",
            "sas = saspy.SASsession()",
            "sas",
        ],
    },
    "sassetupcfg": {
        "prefix": "sassetupcfg",
        "body": [
            "import saspy  # isort: skip",
            "from pathlib import Path  # isort: skip",
            "",
            "print(Path(saspy.SAScfg).as_posix())",
        ],
    },
    "sassetuplib": {
        "prefix": "sassetuplib",
        "body": [
            "sas.submitLST(",
            "    rf\"\"\"",
            "%let myvar=myvalue;",
            "libname mylib 'C:\\temp';",
            "\"\"\",",
            "    method=\"listonly\",",
            ")",
        ],
    },
    "sashead": {
        "prefix": "sashead",
        "body": [
            "df_h = sas.sasdata(\"cars\", \"sashelp\").head()",
            "df_h",
        ],
    },
    "sascount": {
        "prefix": "sascount",
        "body": [
            "n_obs = sas.sasdata(\"cars\", \"sashelp\").obs()",
            "n_obs",
        ],
    },
    "sasshape": {
        "prefix": "sasshape",
        "body": [
            "sd = sas.sasdata(\"cars\", \"sashelp\")",
            "_shape = (sd.obs(), len(sd.columnInfo()))",
            "print(_shape)",
        ],
    },
    "sastop": {
        "prefix": "sastop",
        "body": [
            "df_h1 = sas.sasdata(\"cars\", \"sashelp\").head(1)",
            "print(df_h1.T.to_string())",
        ],
    },
    "sasshapehead": {
        "prefix": "sasshapehead",
        "body": [
            "sd = sas.sasdata(\"cars\", \"sashelp\")",
            "_shape, df_h = (sd.obs(), len(sd.columnInfo())), sd.head()",
            "print(_shape)",
            "df_h",
        ],
    },
    "sasinfo": {
        "prefix": "sasinfo",
        "body": [
            "df_info = sas.sasdata(\"cars\", \"sashelp\").columnInfo()",
            "df_info",
        ],
    },
    "sascol": {
        "prefix": "sascol",
        "body": [
            "df_info = sas.sasdata(\"cars\", \"sashelp\").columnInfo()",
            "cols = df_info[\"Variable\"].tolist()",
            "[c for c in cols if \"cylin\" in c.lower()]",
        ],
    },
    "sasvalc": {
        "prefix": "sasvalc",
        "body": [
            "sas.submitLST(",
            "    f\"\"\"",
            "proc sql;",
            "create table _tmp as",
            "    select",
            "        origin,",
            "        count(1) as n",
            "    from sashelp.cars",
            "    where msrp > 20000",
            "    group by 1",
            "    order by 1;",
            "quit;",
            "\"\"\",",
            "    method=\"listonly\",",
            ")",
            "df = sas.sasdata(\"_tmp\", \"work\").to_df()",
            "df",
        ],
    },
    "sasrun": {
        "prefix": "sasrun",
        "body": [
            "sas.submitLST(",
            "    f\"\"\"",
            "proc print data=sashelp.cars (obs=5);",
            "run;",
            "\"\"\",",
            "    method=\"listonly\",",
            ")",
        ],
    },
    "sasrunlog": {
        "prefix": "sasrunlog",
        "body": [
            "sas.submitLST(",
            "    f\"\"\"",
            "proc print data=sashelp.cars (obs=5);",
            "run;",
            "\"\"\",",
            "    method=\"listandlog\",",
            ")",
        ],
    },
    "sasgrp": {
        "prefix": "sasgrp",
        "body": [
            "sas.submitLST(",
            "    f\"\"\"",
            "proc sql;",
            "create table _tmp as",
            "    select",
            "        origin,",
            "        type,",
            "        count(1) as n",
            "    from sashelp.cars",
            "    where msrp > 20000",
            "    group by 1,2",
            "    order by 1,2;",
            "quit;",
            "\"\"\",",
            "    method=\"listonly\",",
            ")",
            "df = sas.sasdata(\"_tmp\", \"work\").to_df()",
            "df",
        ],
    },
    "sasuni": {
        "prefix": "sasuni",
        "body": [
            "sas.submitLST(",
            "    f\"\"\"",
            "title;",
            "proc univariate data=sashelp.baseball;",
            "    var salary;",
            "    histogram salary / lognormal;",
            "run;",
            "\"\"\",",
            "    method=\"listonly\",",
            ")",
        ],
    },
    "sasfreq": {
        "prefix": "sasfreq",
        "body": [
            "sas.submitLST(",
            "    f\"\"\"",
            "title;",
            "proc freq data=sashelp.cars;",
            "    tables origin type / chisq;",
            "run;",
            "\"\"\",",
            "    method=\"listonly\",",
            ")",
        ],
    },
    "saslogi": {
        "prefix": "saslogi",
        "body": [
            "sas.submitLST(",
            "    \"\"\"",
            "proc logistic data=sashelp.heart plots(only)=roc;",
            "    where status in ('Alive','Dead');",
            "    model status(event='Dead') = height;",
            "    output out=work._pred p=phat;",
            "run;",
            "\"\"\",",
            "    method=\"listonly\",",
            ")",
        ],
    },
    "sassfa": {
        "prefix": "sassfa",
        "body": [
            "sas.submitLST(",
            "    f\"\"\"",
            "proc rank",
            "    data=sashelp.baseball(where=(division in ('East','West')))",
            "    out=_tmp_h_dec",
            "    groups=10;",
            "    var salary;",
            "    ranks decile0;",
            "run;",
            "",
            "proc sql;",
            "create table _tmp_rates as",
            "select",
            "    case",
            "        when missing(decile0) then 'NA'",
            "        else strip(put(decile0 + 1, 2.))",
            "    end as decile,",
            "    count(*) as n,",
            "    mean(division='East') as rate",
            "from _tmp_h_dec",
            "group by decile0",
            "order by decile;",
            "quit;",
            "",
            "proc sgplot data=_tmp_rates;",
            "    vbarparm category=decile response=n / datalabel transparency=0.15;",
            "    series x=decile y=rate / y2axis markers lineattrs=(thickness=2);",
            "    yaxis  label='Volume';",
            "    y2axis label='Rate' values=(0 to 1 by 0.1);",
            "    xaxis  label='Decile' integer;",
            "run;",
            "    \"\"\",",
            "    method=\"listonly\",",
            ")",
        ],
    },
    "sasqry": {
        "prefix": "sasqry",
        "body": [
            "sas.submitLST(",
            "    f\"\"\"",
            "proc sql;",
            "create table _tmp as",
            "    select",
            "        a.make,",
            "        b.type,",
            "        count(1) as n",
            "    from sashelp.cars a",
            "    left join sashelp.cars b",
            "    on",
            "        a.make = b.make and",
            "        a.type = b.type",
            "    where",
            "        a.origin = 'USA'",
            "    group by 1,2",
            "    order by 1,2",
            "    ;",
            "quit;",
            "\"\"\",",
            "    method=\"listonly\",",
            ")",
            "",
            "df = sas.sasdata(\"_tmp\", \"work\").to_df()",
            "df",
        ],
    },
    "sasdrop": {
        "prefix": "sasdrop",
        "body": [
            "sas.submitLST(f\"proc sql;drop table work._tmp;quit;\", method=\"listonly\")",
        ],
    },
    "saswrite": {
        "prefix": "saswrite",
        "body": [
            "sas.df2sd(df, \"_tmp\", \"work\")",
        ],
    },
    "sasctbl": {
        "prefix": "sasctbl",
        "body": [
            "sas.submitLST(f\"proc sql;drop table work._tmp;quit;\", method=\"listonly\")",
            "",
            "sas.submitLST(",
            "    f\"\"\"",
            "proc sql;",
            "create table _tmp as",
            "    select",
            "        a.make,",
            "        b.type,",
            "        count(1) as n",
            "    from sashelp.cars a",
            "    left join sashelp.cars b",
            "    on",
            "        a.make = b.make and",
            "        a.type = b.type",
            "    where",
            "        a.origin = 'USA'",
            "    group by 1,2",
            "    order by 1,2",
            "    ;",
            "quit;",
            "\"\"\",",
            "    method=\"listonly\",",
            ")",
            "",
            "sas.sasdata(\"_tmp\", \"work\").obs()",
        ],
    },
    "sasjoin": {
        "prefix": "sasjoin",
        "body": [
            "sas.submitLST(",
            "    f\"\"\"",
            "proc sql;",
            "create table _tmp as",
            "    select",
            "        a.make,",
            "        b.model,",
            "        b.make as make2",
            "    from sashelp.cars a",
            "    left join sashelp.cars b",
            "    on",
            "        a.make = b.make and",
            "        a.model = b.model",
            "    where",
            "        a.make = 'Ford'",
            "    ;",
            "quit;",
            "\"\"\",",
            "    method=\"listonly\",",
            ")",
            "",
            "sas.sasdata(\"_tmp\", \"work\").obs()",
        ],
    },
    "saserrors": {
        "prefix": "saserrors",
        "body": [
            "print(f\"{sas.saslog().count('ERROR') = }\")",
        ],
    },
    "saslog": {
        "prefix": "saslog",
        "body": [
            "print(sas.lastlog())",
        ],
    }
}